QDRANT_PATH=./data/qdrant
QDRANT_COLLECTION=scholarmind_chunks
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
LLM_API_KEY=your-openrouter-api-key-here
LLM_MODEL=google/gemma-4-26b-a4b-it:free
LLM_BASE_URL=https://openrouter.ai/api/v1
CHUNK_SIZE=800
CHUNK_OVERLAP=150
RETRIEVAL_CANDIDATE_K=20
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_RERANK_SCORE=-7.0
LLM_MAX_TOKENS=512
# Optional: raises the Semantic Scholar unauthenticated rate limit for literature discovery
# and citation-graph lookups. Leave empty to use the shared free-tier limit.
S2_API_KEY=
# Optional: only needed to push references to Zotero from the web app. Never commit real
# values here — leave blank and set a key for the current session in the sidebar instead.
ZOTERO_API_KEY=
ZOTERO_LIBRARY_ID=
ZOTERO_LIBRARY_TYPE=user
# Optional: a vision-capable model (via the same LLM_API_KEY/LLM_BASE_URL) for Figure Q&A to
# send the actual figure image, not just its caption. Must support image input — an
# OpenRouter multimodal Gemini model, e.g. google/gemini-2.0-flash-001, is a reasonable
# choice (not necessarily a "flash-lite"/text-only variant). Leave empty to always use
# caption-only Figure Q&A.
VISION_MODEL=
